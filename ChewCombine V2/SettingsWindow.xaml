<Window x:Class="ChewCombine_V2.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="设置" Height="350" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TextBlock Text="设置喵" FontTypography="Title" Margin="0,10,0,20" />

        <StackPanel Grid.Row="1">
            <StackPanel Margin="0,0,0,20">
                <ui:TextBlock Text="Rest audio 路径" FontWeight="Medium" Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="RestPathTextBox" Grid.Column="0" PlaceholderText="请选择音频..." IsReadOnly="True" />
                    <ui:Button Grid.Column="1" Click="SelectRestAudio_Click" ToolTip="选取音频">
                        <ui:SymbolIcon Symbol="Folder24" />
                    </ui:Button>
                </Grid>
            </StackPanel>

            <StackPanel>
                <ui:TextBlock Text="BackGround 路径" FontWeight="Medium" Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="BgPathTextBox" Grid.Column="0" PlaceholderText="请选择背景图..." IsReadOnly="True" />
                    <ui:Button Grid.Column="1" Click="SelectBgImage_Click" ToolTip="选取图片">
                        <ui:SymbolIcon Symbol="Folder24" />
                    </ui:Button>
                </Grid>
            </StackPanel>
        </StackPanel>

        <ui:Button Grid.Row="2" 
                   Content="关闭" 
                   HorizontalAlignment="Right" 
                   Width="100" 
                   Click="CloseButton_Click" />
    </Grid>
</Window>